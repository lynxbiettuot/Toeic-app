# ---------------------------------------------------------
# DATABASE CONFIGURATION (MySQL / XAMPP)
# ---------------------------------------------------------
# DATABASE_URL: Dùng cho Prisma migrate/generate
# Định dạng: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://root:@localhost:3306/toeicapp"

# Các biến lẻ dùng cho custom adapter trong code
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_NAME="toeicapp"
DATABASE_USER="root"
DATABASE_PASSWORD=""

# ---------------------------------------------------------
# SERVER CONFIGURATION
# ---------------------------------------------------------
PORT=3000

# ---------------------------------------------------------
# AUTHENTICATION (JWT)
# ---------------------------------------------------------
# Nhập chuỗi ký tự ngẫu nhiên bất kỳ để bảo mật token
JWT_ACCESS_SECRET="your_access_token_secret_here"
JWT_REFRESH_SECRET="your_refresh_token_secret_here"

# ---------------------------------------------------------
# EMAIL CONFIGURATION (Gửi OTP)
# ---------------------------------------------------------
# EMAIL_USER: Địa chỉ Gmail của bạn
EMAIL_USER="your-email@gmail.com"
# EMAIL_PASS: MẬT KHẨU ỨNG DỤNG (App Password), không phải mật khẩu đăng nhập Gmail
# Link tạo: https://myaccount.google.com/apppasswords
EMAIL_PASS="your_app_password_here"

# ---------------------------------------------------------
# AI CONFIGURATION (Google Gemini)
# ---------------------------------------------------------
# Lấy key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
