# Copy this file to .env only if you want to override the automatic backend URL detection.
# For Expo Go on a physical phone, the app can infer your computer's LAN IP automatically.
# Example override for a physical phone on the same Wi-Fi:
# API_BASE_URL=http://192.168.1.10:3000

API_BASE_URL=http://192.168.0.3:3000
API_PORT=3000

# Cloudinary Config
# Get Cloud Name from Dashboard
EXPO_PUBLIC_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/YOUR_CLOUD_NAME/image/upload
# Create an "Unsigned" upload preset in Settings -> Upload
EXPO_PUBLIC_UPLOAD_PRESET=your_unsigned_preset_name
