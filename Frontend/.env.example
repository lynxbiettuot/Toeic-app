# ---------------------------------------------------------
# BACKEND API CONFIGURATION
# ---------------------------------------------------------
# API_BASE_URL: Địa chỉ của Backend Server
# - Nếu dùng Máy ảo (Android Studio): http://10.0.2.2:3000
# - Nếu dùng Máy thật (Expo Go trên điện thoại): http://[IP_MAY_TINH]:3000
API_BASE_URL="http://10.0.2.2:3000"

# API_PORT: Cổng của Backend Server (mặc định 3000)
API_PORT=3000

# ---------------------------------------------------------
# IMAGE UPLOAD CONFIGURATION (Cloudinary)
# ---------------------------------------------------------
# EXPO_PUBLIC_CLOUDINARY_URL: Link API upload của Cloudinary
# Định dạng: https://api.cloudinary.com/v1_1/[YOUR_CLOUD_NAME]/image/upload
EXPO_PUBLIC_CLOUDINARY_URL="https://api.cloudinary.com/v1_1/your_cloud_name/image/upload"

# EXPO_PUBLIC_UPLOAD_PRESET: Tên Preset (chế độ Unsigned)
# Lấy trong Settings -> Upload của Cloudinary
EXPO_PUBLIC_UPLOAD_PRESET="your_unsigned_preset_name"
